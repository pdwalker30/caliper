# ============================================================================
# Caliper — Environment Configuration
# ============================================================================
# Copy to .env and fill in values BEFORE running `docker compose up`.
#
# NEVER commit .env — it is in .gitignore for a reason.
#
# Helper:  ./scripts/generate-secrets.sh
#   Generates strong random values for the *_SECRET / *_KEY / *_SALT vars
#   and prints them to stdout — you copy/paste into .env.

# ----------------------------------------------------------------------------
# Langfuse self-hosted — secrets
# ----------------------------------------------------------------------------
# Generate each of these with: openssl rand -hex 32
# Picking weak / shared values defeats the encryption-at-rest story.
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_NEXTAUTH_URL=http://localhost:3000
LANGFUSE_SALT=
# Must be exactly 64 hex chars (32 bytes). Used to encrypt secret keys in DB.
LANGFUSE_ENCRYPTION_KEY=

# ----------------------------------------------------------------------------
# Langfuse self-hosted — datastore credentials
# ----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=clickhouse

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=miniosecret

# Redis password — required (Langfuse worker auths against this)
REDIS_AUTH=

# ----------------------------------------------------------------------------
# LiteLLM Proxy
# ----------------------------------------------------------------------------
# Master key for talking to the proxy. Must start with `sk-`.
# Caliper uses this as the API key when calling the proxy.
LITELLM_MASTER_KEY=

# ----------------------------------------------------------------------------
# Upstream LLM Provider API Keys
# ----------------------------------------------------------------------------
# Fill in only the providers you actually want to route to. Empty = disabled.
# LiteLLM reads these from its container env and uses them when routing.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
AZURE_API_KEY=
AZURE_API_BASE=

# ----------------------------------------------------------------------------
# Caliper (Python runner — used by `python -m caliper.eval_runner ...`)
# ----------------------------------------------------------------------------
# These point Caliper at the running stack above.

LANGFUSE_HOST=http://localhost:3000
# Populate these AFTER first launch:
#   1. Open http://localhost:3000
#   2. Create account (local only) + project
#   3. Settings -> API Keys -> Create new key
#   4. Paste public + secret keys here
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# LiteLLM proxy URL Caliper points at. Uses LITELLM_MASTER_KEY above as the key.
LITELLM_BASE_URL=http://localhost:4000
